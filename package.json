{
  "name": "workspace",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev:frontend": "vite --config frontend/vite.config.ts --host 0.0.0.0",
    "dev:backend": "npx tsx backend/src/index.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build": "npm run typecheck && npm run build:frontend && npm run build:backend",
    "start": "npm run build && node backend/dist/index.js",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs"
  },
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "lib/*"
  ],
